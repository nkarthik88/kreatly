{
  "manifest_version": 3,
  "name": "Kreatly: Your AI Ghostwriter",
  "version": "1.1",
  "description": "Your Notion workspace connected directly to LinkedIn, X, and Reddit.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["activeTab", "tabs", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.notion.so/*",
    "https://*.notion.com/*",
    "https://app.notion.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*",
    "https://*.reddit.com/*"
  ],
  "action": { "default_popup": "popup.html", "default_icon": "icon.png" }
}
